# API 키 설정
# API_KEY: 메인 Nexon Open API 키 (live). DAG/수집에서 사용.
API_KEY=your_nexon_api_key_here
# API_KEY_1, API_KEY_2: 레거시 (기존 1, 2/test). 설정 시 API_KEY보다 우선하지 않음.
# API_KEY_1=your_api_key_1_here
# API_KEY_2=your_api_key_2_here

# 날짜 설정 (선택사항, Airflow Variables에서도 설정 가능)
DATE=2025-08-13

# DW Postgres 연결
# 우선순위: DW_DATABASE_URL > DW_PG* > PG*
# 로컬 docker-compose 기본값(airflow DB를 DW 스키마로 사용):
DW_DATABASE_URL=postgresql://airflow:airflow@postgres:5432/airflow
# 외부 DB를 쓰려면 위 값을 주석 처리하고 아래 값을 사용
# DW_DATABASE_URL=postgresql://user:password@host:5432/dbname
# DW_PGHOST=your_host
# DW_PGPORT=5432
# DW_PGDATABASE=your_db
# DW_PGUSER=your_user
# DW_PGPASSWORD=your_password
# DW_SSLMODE=require

# Nexon 공지 백필 (nexon_notice_dag)
# NEXON_API_KEY: 없으면 API_KEY 사용
# NEXON_API_KEY=your_nexon_api_key
# ANTHROPIC_API_KEY: patch_note LLM 생성용
# ANTHROPIC_API_KEY=your_anthropic_api_key
# STATIC_HOST_DIR: 서버에서 ~/static/update에 생성하려면 /home/jamin/static 설정 (docker 볼륨용)
# STATIC_HOST_DIR=/home/jamin/static

# Supabase (sync_supabase, reset_supabase_dm_tables, pull_character_master_from_supabase)
# SUPABASE_URL: 기본값 있음. 다른 프로젝트 사용 시 설정.
# SUPABASE_SERVICE_KEY 또는 SUPABASE_SERVICE_ROLE_KEY: 필수
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your_service_role_key

# Airflow 설정 (docker-compose.yml에서 사용)
AIRFLOW_UID=50000
AIRFLOW_WWW_USER_USERNAME=airflow
AIRFLOW_WWW_USER_PASSWORD=airflow
