# API 키 설정
# API_KEY_1: 목요일용 (최근 수요일 데이터 수집)
API_KEY_1=your_api_key_1_here
# API_KEY_2: 평일용 (과거 수요일 데이터 백필)
API_KEY_2=your_api_key_2_here
# API_KEY는 API_KEY_2 별칭 (하위 호환용, 선택)
# API_KEY=your_api_key_2_here

# 날짜 설정 (선택사항, Airflow Variables에서도 설정 가능)
DATE=2025-08-13

# DW Postgres 연결
# 우선순위: DW_DATABASE_URL > DW_PG* > PG*
# 로컬 docker-compose 기본값(airflow DB를 DW 스키마로 사용):
DW_DATABASE_URL=postgresql://airflow:airflow@postgres:5432/airflow
# 외부 DB를 쓰려면 위 값을 주석 처리하고 아래 값을 사용
# DW_DATABASE_URL=postgresql://user:password@host:5432/dbname
# DW_PGHOST=your_host
# DW_PGPORT=5432
# DW_PGDATABASE=your_db
# DW_PGUSER=your_user
# DW_PGPASSWORD=your_password
# DW_SSLMODE=require

# Airflow 설정 (docker-compose.yml에서 사용)
AIRFLOW_UID=50000
AIRFLOW_WWW_USER_USERNAME=airflow
AIRFLOW_WWW_USER_PASSWORD=airflow
